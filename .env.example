# Canonical URL (e.g., https://meetprerna.com)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Sanity CMS (Required for Content)
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="v2024-07-22"
SANITY_API_READ_TOKEN="your_read_token_for_previews"

# Resend (Required for Contact/Book forms)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="studio@meetprerna.com"

# Analytics (Optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="meetprerna.com"

# Development Overrides (Optional)
# Set to 'true' to use GSAP stub instead of GSAP Trial plugins in dev
NEXT_PUBLIC_GSAP_STUBS="false"
