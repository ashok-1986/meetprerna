{
  "name": "meetprerna",
  "version": "1.0.0",
  "private": true,
  "description": "MeetPrerna — Mumbai-based creative studio & tattoo artist portfolio. Immersive, GSAP-driven, WebGL-accented.",
  "author": "MeetPrerna Studio <studio@meetprerna.com>",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --grep @visual",
    "lighthouse": "lhci autorun",
    "analyze": "next-bundle-analyzer",
    "clean": "rimraf .next .turbo node_modules/.cache",
    "prepare": "husky install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.2",
    "@radix-ui/react-dropdown-menu": "2.1.2",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-tabs": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.4",
    "@react-three/drei": "9.114.3",
    "@react-three/fiber": "8.17.10",
    "@t3-oss/env-nextjs": "0.11.1",
    "class-variance-authority": "0.7.0",
    "clsx": "2.1.1",
    "embla-carousel-react": "8.5.1",
    "feed": "4.2.2",
    "framer-motion": "11.11.17",
    "gsap": "3.15.0",
    "lenis": "1.1.13",
    "lucide-react": "0.460.0",
    "next": "14.2.18",
    "next-intl": "3.25.1",
    "next-themes": "0.4.3",
    "posthog-js": "1.200.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-intersection-observer": "9.13.1",
    "sharp": "0.33.5",
    "sitemap": "8.0.0",
    "tailwind-merge": "2.5.4",
    "three": "0.169.0",
    "use-debounce": "10.0.4",
    "zod": "3.23.8",
    "zustand": "5.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.0",
    "@lhci/cli": "0.14.0",
    "@playwright/test": "1.48.2",
    "@storybook/addon-a11y": "8.4.2",
    "@storybook/addon-essentials": "8.4.2",
    "@storybook/nextjs": "8.4.2",
    "@storybook/react": "8.4.2",
    "@tailwindcss/typography": "0.5.15",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.0.1",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "20.16.10",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@types/three": "0.169.0",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "@vitest/coverage-v8": "2.1.5",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.18",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.2",
    "eslint-plugin-react-hooks": "5.0.0",
    "glslify": "7.1.1",
    "happy-dom": "15.7.4",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "next-bundle-analyzer": "0.6.8",
    "postcss": "8.4.47",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "0.6.8",
    "rimraf": "6.0.1",
    "rollup-plugin-glsl": "1.3.0",
    "storybook": "8.4.2",
    "tailwindcss": "3.4.14",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
